# ── SASA Analytics — environment variables ───────────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ── Server ───────────────────────────────────────────────────────────────────
# Defaults to 127.0.0.1 (loopback). Set 0.0.0.0 ONLY in a container/behind a proxy.
HOST=127.0.0.1
PORT=8001

# ── Security ─────────────────────────────────────────────────────────────────
# REQUIRED IN PRODUCTION. When set, the management API (/api/projects, create,
# get-by-id) requires `Authorization: Bearer <ADMIN_SECRET>`. If left empty the
# management API is OPEN (dev only). Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
ADMIN_SECRET=

# ── Demo project ─────────────────────────────────────────────────────────────
# API key for the built-in demo project. Set to a real random value in production.
# Generate with: python -c "import secrets; print('sf_' + secrets.token_urlsafe(16))"
DEMO_API_KEY=sf_demo_key_dev_only

# ── Rate limiting ─────────────────────────────────────────────────────────────
# Events per second allowed per CLIENT IP (ingest endpoints). Keyed by IP, not
# by api_key, so a client cannot mint fresh budget by rotating its key.
RATE_LIMIT_INGEST=500
# Requests per minute allowed per IP on management endpoints
RATE_LIMIT_MGMT=60

# ── Abuse / resource limits ──────────────────────────────────────────────────
# Max HTTP request body size in bytes (default 1 MB) and max events per batch.
MAX_BODY_BYTES=1048576
MAX_BATCH_EVENTS=1000
# Max distinct keys retained per in-memory metric dict (caps memory growth).
MAX_DISTINCT_KEYS=5000

# ── Spark ─────────────────────────────────────────────────────────────────────
SPARK_EVENTS_DIR=spark/data/events
SPARK_OUTPUT_DIR=spark/output
SPARK_CHECKPOINT_DIR=spark/checkpoints
# How many event files Spark processes per trigger
SPARK_MAX_FILES_PER_TRIGGER=20
# Trigger interval in seconds
SPARK_TRIGGER_INTERVAL=10

# ── Data retention ────────────────────────────────────────────────────────────
# Delete processed event files older than this many days (0 = never delete)
EVENT_FILE_RETENTION_DAYS=7
